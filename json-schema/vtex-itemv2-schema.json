{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ItemV2",
  "title": "ItemV2",
  "required": [
    "id",
    "quantity"
  ],
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "SKU ID of the item that will be changed.",
      "example": "1"
    },
    "quantity": {
      "type": "integer",
      "description": "Quantity of the item been changed.",
      "example": 1
    }
  },
  "example": {
    "id": "1",
    "quantity": 1
  }
}