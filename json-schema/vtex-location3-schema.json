{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Location3",
  "title": "Location3",
  "required": [
    "zipCode",
    "country",
    "point"
  ],
  "type": "object",
  "properties": {
    "zipCode": {
      "type": "string"
    },
    "country": {
      "type": "string"
    },
    "point": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "description": ""
    }
  },
  "example": {
    "zipCode": "22780084",
    "country": "BRA",
    "point": [
      -43.32475950000003,
      -22.9999575
    ]
  }
}