{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CartProduct",
  "title": "CartProduct",
  "type": "object",
  "description": "Product information.",
  "required": [
    "productId",
    "quantity"
  ],
  "properties": {
    "productId": {
      "type": "string",
      "description": "Unique identifier of the product.",
      "example": "ABC123"
    },
    "quantity": {
      "type": "number",
      "description": "Quantity of the product.",
      "example": 2
    }
  }
}