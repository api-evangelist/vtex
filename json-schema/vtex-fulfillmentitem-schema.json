{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/fulfillmentItem",
  "title": "fulfillmentItem",
  "description": "Details of an item to be fulfilled.",
  "required": [
    "id",
    "quantity",
    "seller"
  ],
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "SKU ID.",
      "example": "6"
    },
    "quantity": {
      "type": "integer",
      "description": "Quantity of items of the SKU in the cart.",
      "example": 1
    },
    "seller": {
      "type": "string",
      "description": "ID of the seller registered in VTEX.",
      "example": "01"
    }
  }
}