{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Department",
  "title": "Department",
  "required": [
    "Quantity",
    "Name",
    "Link"
  ],
  "type": "object",
  "properties": {
    "Quantity": {
      "type": "integer",
      "format": "int32"
    },
    "Name": {
      "type": "string"
    },
    "Link": {
      "type": "string"
    }
  },
  "example": {
    "Quantity": 20,
    "Name": "Eletro-Eletronicos",
    "Link": "/Eletro-Eletronicos"
  }
}