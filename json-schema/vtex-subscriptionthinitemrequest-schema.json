{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SubscriptionThinItemRequest",
  "title": "SubscriptionThinItemRequest",
  "type": "object",
  "properties": {
    "skuId": {
      "type": "string",
      "nullable": true,
      "title": "skuId",
      "description": "SKU ID.",
      "example": "12"
    },
    "quantity": {
      "type": "integer",
      "format": "int32",
      "title": "quantity",
      "description": "Amount of units in the cart.",
      "example": 5
    },
    "manualPrice": {
      "type": "integer",
      "format": "int32",
      "title": "manualPrice",
      "description": "Manual price.",
      "default": null,
      "nullable": true,
      "example": 40
    }
  },
  "additionalProperties": false
}