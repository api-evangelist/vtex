{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SKUServiceValueResponse",
  "title": "SKUServiceValueResponse",
  "type": "object",
  "required": [
    "SkuServiceTypeId",
    "Name",
    "Value",
    "Cost"
  ],
  "properties": {
    "Id": {
      "type": "integer",
      "description": "SKU service value ID.",
      "example": 2
    },
    "SkuServiceTypeId": {
      "type": "integer",
      "description": "SKU service type ID.",
      "example": 2
    },
    "Name": {
      "type": "string",
      "description": "SKU service value name. Maximum of 100 characters.",
      "example": "Test ServiceValue API"
    },
    "Value": {
      "type": "number",
      "description": "SKU service value value.",
      "example": 10.5
    },
    "Cost": {
      "type": "number",
      "description": "SKU service value cost.",
      "example": 10.5
    }
  },
  "example": {
    "Id": 2,
    "SkuServiceTypeId": 2,
    "Name": "Test ServiceValue API",
    "Value": 10.5,
    "Cost": 10.5
  }
}