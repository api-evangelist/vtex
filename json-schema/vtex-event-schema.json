{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Event",
  "title": "Event",
  "required": [
    "city",
    "state",
    "description",
    "date"
  ],
  "type": "object",
  "properties": {
    "city": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string"
    }
  },
  "example": {
    "city": "Rio de Janeiro",
    "state": "RJ",
    "description": "Coletado pela transportadora",
    "date": "2015-06-23"
  }
}