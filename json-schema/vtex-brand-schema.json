{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Brand",
  "title": "Brand",
  "required": [
    "Quantity",
    "Name",
    "Link"
  ],
  "type": "object",
  "properties": {
    "Quantity": {
      "type": "integer",
      "format": "int32"
    },
    "Name": {
      "type": "string"
    },
    "Link": {
      "type": "string"
    }
  },
  "example": {
    "Quantity": 1,
    "Name": "Philips",
    "Link": "/eletronicos/tv/Philips"
  }
}