                  "type": "string",
                  "description": "Three letter country code."
                }
              },
              "itemId": {
                "type": "string",
                "description": "Item ID."
              },
              "deliveryChannels": {
                "type": "array",
                "description": "List of available delivery channels.",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Delivery channel ID."
                    }
                  }
                }
              }
            }
          }
        },
        "selectedAddresses": {
