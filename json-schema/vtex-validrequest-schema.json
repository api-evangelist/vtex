{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ValidRequest",
  "title": "ValidRequest",
  "required": [
    "value",
    "installments"
  ],
  "type": "object",
  "description": "Installments options response body information.",
