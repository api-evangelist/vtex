{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ShippingPrice",
  "title": "ShippingPrice",
  "required": [
    "value",
    "currency"
  ],
  "type": "object",
  "description": "Shipping cost information.",
  "properties": {
    "value": {
      "type": "integer",
      "format": "int32",
      "description": "Shipping cost in cents."
    },
    "currency": {
      "type": "string",
      "description": "Currency code in [ISO 4217](https://www.iban.com/currency-codes) format."
    }
  },
  "example": {
    "value": 0,
    "currency": "USD"
  }
}