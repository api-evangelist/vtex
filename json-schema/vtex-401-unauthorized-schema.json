{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/401_Unauthorized",
  "title": "401_Unauthorized",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "type",
    "title",
    "status",
    "traceId"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "https://tools.ietf.org/html/rfc7235#section-3.1"
      ]
    },
    "title": {
      "type": "string",
      "enum": [
        "Unauthorized"
      ]
    },
    "status": {
      "type": "integer",
      "enum": [
        401
      ]
    },
    "traceId": {
      "type": "string",
      "pattern": "^00-[0-9a-f]{32}-[0-9a-f]{16}-00$"
    }
  }
}