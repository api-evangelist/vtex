                          "ListPrice": {
                            "description": "List price of the item.",
                            "type": "number"
                          },
                          "spotPrice": {
                            "description": "Spot price.",
                            "type": "number"
                          },
                          "taxPercentage": {
                            "description": "Tax percentage.",
                            "type": "number"
