{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SKUService",
  "title": "SKUService",
  "type": "object",
  "properties": {
    "Id": {
      "type": "integer",
      "description": "SKU service ID.",
      "example": 1
    },
    "SkuServiceTypeId": {
      "type": "integer",
      "description": "SKU service type ID.",
      "example": 1
    },
    "SkuServiceValueId": {
      "type": "integer",
      "description": "SKU service value ID.",
      "example": 1
    },
    "SkuId": {
      "type": "integer",
      "description": "SKU ID.",
      "example": 1
    },
    "Name": {
      "type": "string",
      "description": "SKU service name. Maximum of 50 characters.",
      "example": "Engraving"
    },
    "Text": {
      "type": "string",
      "description": "Internal description of the SKU service. Maximum of 100 characters.",
      "example": "Name engraving additional service."
    },
    "IsActive": {
      "type": "boolean",
      "description": "Defines if the SKU service is active or not.",
      "example": true
    }
  },
  "example": {
    "Id": 1,
    "SkuServiceTypeId": 1,
    "SkuServiceValueId": 1,
    "SkuId": 1,
    "Name": "name",
    "Text": "text",
    "IsActive": false
  }
}