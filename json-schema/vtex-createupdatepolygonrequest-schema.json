{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CreateUpdatePolygonRequest",
  "title": "Create/UpdatePolygonRequest",
  "required": [
    "name",
    "geoShape"
  ],
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "geoShape": {
      "title": "GeoShape",
      "required": [
        "coordinates"
      ],
      "type": "object",
      "properties": {
        "coordinates": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      }
    }
  }
}