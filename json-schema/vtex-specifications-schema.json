{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Specifications",
  "title": "Specifications",
  "required": [
    "Embalagem"
  ],
  "type": "object",
  "properties": {
    "Embalagem": {
      "type": "string",
      "description": "Packaging specifications. Should include package's weight."
    }
  },
  "example": {
    "Embalagem": "3 kg"
  }
}