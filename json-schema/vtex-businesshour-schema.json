{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/BusinessHour",
  "title": "BusinessHour",
  "required": [
    "dayOfWeek",
    "openingTime",
    "closingTime"
  ],
  "type": "object",
  "properties": {
    "dayOfWeek": {
      "type": "integer",
      "format": "int32"
    },
    "openingTime": {
      "type": "string"
    },
    "closingTime": {
      "type": "string"
    }
  },
  "example": {
    "dayOfWeek": 1,
    "openingTime": "08:00:00",
    "closingTime": "20:00:00"
  }
}