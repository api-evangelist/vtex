{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AlternateIds",
  "title": "AlternateIds",
  "type": "object",
  "description": "Array with alternate SKU IDs, such as EAN and `RefId`.",
  "properties": {
    "Ean": {
      "type": "string",
      "description": "SKU EAN."
    },
    "RefId": {
      "type": "string",
      "description": "SKU reference ID."
    }
  },
  "example": {
    "Ean": "8781",
    "RefId": "878181"
  }
}